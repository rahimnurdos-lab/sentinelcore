# Frontend: Sidebar Telegram button
VITE_TELEGRAM_BOT_URL=https://t.me/your_bot_username

# Telegram bot runtime (scripts/telegram-bot.js)
TELEGRAM_BOT_TOKEN=1234567890:your_real_telegram_bot_token
SENTINEL_APP_URL=https://your-sentinel-app-url
BOT_TITLE=Sentinel Cyber Bot
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-NEON-HOST/DBNAME?sslmode=require
TELEGRAM_GROUP_MODERATION_DEFAULT=true
TELEGRAM_DEFAULT_MODE=balanced
TELEGRAM_DEFAULT_ACTION=delete_explain
TELEGRAM_MUTE_MINUTES=15
TELEGRAM_MAX_RECENT_INCIDENTS=50

# Optional: restrict usage to selected chats only (comma separated)
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
